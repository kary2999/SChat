{
  "manifest_version": 3,
  "name": "SChat",
  "version": "1.1.0",
  "description": "Encrypted ephemeral P2P chat — no server, no logs, no trace",
  "action": {
    "default_popup": "index.html",
    "default_title": "SChat"
  },
  "permissions": [
    "clipboardRead"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
